# 房屋管理系统配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== HTTP 服务配置 ====================
# HTTP 服务监听地址
HTTP_ADDR=:8080

# ==================== 数据库配置 ====================
# SQLite 数据库文件路径
DATABASE_DSN=data/ddd.db

# ==================== 日志配置 ====================
# 运行环境: development 或 production
LOG_ENVIRONMENT=development
# 日志级别: debug, info, warn, error
LOG_LEVEL=info
# 日志输出路径: stdout, stderr 或文件路径
LOG_OUTPUT=./house.log

# ==================== OIDC 认证配置 ====================
# 是否启用开发模式（跳过 OIDC，使用 mock 用户）
OIDC_DEV_MODE=false
# Keycloak Issuer URL
OIDC_ISSUER_URL=http://localhost:8081/realms/master
# Client ID
OIDC_CLIENT_ID=ddd-app
# Client Secret
OIDC_CLIENT_SECRET=DsAR9oz4OzkYF96KcS65cb1bU9vur1QY
# 回调 URL
OIDC_REDIRECT_URL=http://localhost:8080/oauth2/callback
# 前端地址（登录/登出后跳转）
OIDC_FRONTEND_URL=http://localhost:5173
# OIDC Scope 配置（定义请求哪些用户信息）
# openid: 必需，标识这是 OIDC 请求
# profile: 获取用户基本资料（姓名、头像等）
# email: 获取用户邮箱
# roles: 获取用户角色（用于权限控制）
# 注意：自定义属性（如 hello）不需要在这里配置，通过 Mapper 配置即可
OIDC_SCOPES=openid,profile,email,roles
# Session 加密密钥（生产环境请使用强随机密钥）
OIDC_SESSION_SECRET=9D9YhTWHanAvYkO3l48F9ILCUgazCH36
# Session 有效期（例如: 24h, 7d, 168h）
OIDC_SESSION_TTL=24h

# 房屋管理系统配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== HTTP 服务配置 ====================
# HTTP 服务监听地址
HTTP_ADDR=:8080

# ==================== 数据库配置 ====================
# SQLite 数据库文件路径
DATABASE_DSN=data/ddd.db

# ==================== 日志配置 ====================
# 运行环境: development 或 production
LOG_ENVIRONMENT=development
# 日志级别: debug, info, warn, error
LOG_LEVEL=info
# 日志输出路径: stdout, stderr 或文件路径
LOG_OUTPUT=stdout

# ==================== OIDC 认证配置 ====================
# Keycloak Issuer URL
OIDC_ISSUER_URL=http://localhost:8081/realms/ddd-realm
# Client ID
OIDC_CLIENT_ID=ddd-app
# Client Secret
OIDC_CLIENT_SECRET=your-client-secret-here
# 回调 URL
OIDC_REDIRECT_URL=http://localhost:8080/oauth2/callback
# Session 加密密钥（生产环境请使用强随机密钥）
OIDC_SESSION_SECRET=your-session-secret-key-here-min-32-chars
# Session 有效期（例如: 24h, 7d, 168h）
OIDC_SESSION_TTL=24h
